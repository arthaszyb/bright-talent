# .env.example — Local development configuration (gitignored)
# Copy this to .env and fill in real values for local testing.
# DO NOT commit .env to git. Production secrets are injected at deploy time.

# === Change Gateway ===
# Mock service URL for local testing; points to the integrated mock gateway
CHANGE_GATEWAY_BASE=http://localhost:8801

# === Service Catalog ===
# Path to the mock service catalog (used by the Change Gateway to validate scope)
DE_SCOPE_SERVICE_CATALOG=../../mocks/service_catalog.json

# === Chat Platform Integration (if bridge.enabled: true) ===
# For local development, these are optional. In production, the Instance Manager
# injects real credentials from secrets management.
CHATOPS_APP_ID=changeme
CHATOPS_APP_SECRET=changeme
CHATOPS_SIGNING_SECRET=changeme

# === Optional: Ticket/Metrics API Keys ===
# Uncomment and populate if using ticket-review or metrics-fetch skills
# TICKET_API_KEY=changeme
# METRICS_API_KEY=changeme
