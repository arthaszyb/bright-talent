# .env.example — Local development secrets (gitignored)
# Copy this to .env and fill in real values for local testing.
# DO NOT commit .env to git. Production secrets are injected as env vars at deploy time.

# Change Gateway base URL (where the agent's skills fetch tickets, metrics, etc.)
CHANGE_GATEWAY_BASE=http://localhost:8801

# Chat platform credentials (bridge mode only — required if bridge.enabled: true in instance.yaml)
# In production, these are injected by the Instance Manager.
# For local dev, use placeholder values that match your mock setup.
CHATOPS_APP_ID=<YOUR_VALUE>
CHATOPS_APP_SECRET=<YOUR_VALUE>
CHATOPS_SIGNING_SECRET=<YOUR_VALUE>

# Optional: any other credentials your skills or MCP servers need
# TICKET_API_KEY=<YOUR_VALUE>
# METRICS_API_KEY=<YOUR_VALUE>
