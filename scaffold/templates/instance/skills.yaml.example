# skills.yaml — Skill dependencies for this intelligent-staff instance
# Validated and locked at build time; the builder resolves each dependency
# against its registry, pins tag -> commit, installs into runtime/.claude/skills/,
# and writes skills-lock.json.

# Skill registries. In this demo the local registry is the skills/ repo
# two levels above the instance directory.
registries:
  local:
    url: "file://../../skills"

default_registry: local

# Declared skill dependencies, pinned to a release tag.
dependencies: {}

# Example (uncomment to use):
# dependencies:
#   ticket-review:
#     registry: local
#     tag: "ticket-review/v0.1.0"
