{# bridge.yaml.j2 — Bridge configuration rendered at build time into <instance>/log/bridge-config.yaml.
   Variable contract (StrictUndefined):
   - bridge: the instance.yaml `bridge:` mapping (enabled, chat_platform, server, auth,
             sessions, agent, memory — all sub-keys optional, demo defaults applied here)
   - env: environment variables for secret references like {{ env.VAR }}
   Output schema must match bridge/bridge/config.py (the demo bridge app's loader).
#}
# Bridge configuration (generated — do not edit; edit instance.yaml `bridge:` and rebuild)
# Secrets are injected as environment variables at deploy time.

chat:
  app_id: "{{ env.CHATOPS_APP_ID | default('demo-app-id', true) }}"
  signing_secret: "{{ env.CHATOPS_SIGNING_SECRET | default('changeme-demo-secret', true) }}"
  api_base_url: "{{ bridge.get('chat_platform', {}).get('api_base_url', 'http://localhost:9101') }}"
  bot_id: "{{ bridge.get('chat_platform', {}).get('bot_id', 'demo-bot') }}"

server:
  host: "{{ bridge.get('server', {}).get('host', '127.0.0.1') }}"
  port: {{ bridge.get('server', {}).get('port', 9100) }}
  pid_file: "log/bridge-http.pid"

agent:
  claude_cmd: "{{ bridge.get('agent', {}).get('backend', 'claude') }}"
  permission_mode: "{{ bridge.get('agent', {}).get('permission_handling', 'acceptEdits') }}"
  extra_args: {{ bridge.get('agent', {}).get('extra_args', []) | tojson }}
  env:
    CHANGE_GATEWAY_BASE: "{{ env.CHANGE_GATEWAY_BASE | default('http://localhost:8801', true) }}"

sessions:
  idle_timeout_seconds: {{ bridge.get('sessions', {}).get('idle_timeout_seconds', 60) }}
  turn_timeout_seconds: {{ bridge.get('sessions', {}).get('turn_timeout_seconds', 300) }}
  max_sessions: {{ bridge.get('sessions', {}).get('max_sessions', 20) }}
  working_dir: "./runtime"
  data_dir: "./log/bridge-data"

auth:
  allowed_users:
{% for user in bridge.get('auth', {}).get('allowed_users', []) %}
    - "{{ user }}"
{% endfor %}
  admin_users:
{% for admin in bridge.get('auth', {}).get('admin_users', []) %}
    - "{{ admin }}"
{% endfor %}

memory:
  enabled: {{ bridge.get('memory', {}).get('enabled', true) | lower }}
  context_min_chars: 5
  context_max_chars: {{ bridge.get('memory', {}).get('context_max_chars', 2000) }}
  context_max_results: {{ bridge.get('memory', {}).get('context_max_results', 3) }}

reply_transport: "log+callback"
